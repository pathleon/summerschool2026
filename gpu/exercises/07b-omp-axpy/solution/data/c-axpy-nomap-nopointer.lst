11.           int main(int argc, char* argv[]) {
12.               // Array size
13.               int n = 102400;
14.               if (argc > 1) {
15.                   n = std::stoi(argv[1]);
16.               }
17.               printf("Array size n = %d\n", n);
18.           
19.               double alpha;
20.               std::vector<double> x(n), y(n);
21.           
22.               // Initialization
23.               alpha = 3.0;
24.               for (int i = 0; i < n; i++) {
25.                   double frac = 1.0 / ((double) (n - 1));
26.                   x[i] = i * frac;
27.                   y[i] = i * frac * 100;
28.               }
29.           
30.               // Print input values
31.               printf("Input:\n");
32.               printf("a = %8.4f\n", alpha);
33.               print_array("x", x);
34.               print_array("y", y);
35.           
36.               // Calculate axpy
37. + I 0--<>     #pragma omp target teams distribute parallel for
38. +   M---<     for (int i = 0; i < n; i++) {
39. + I M             y[i] += alpha * x[i];
40.     M--->     }
41.           
42.               // Print output values
43.               printf("Output:\n");
44.               print_array("y", y);
45.           
46.               return 0;
47.           }

