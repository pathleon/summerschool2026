    6.                 
    7.                 program axpy
    8.                   use helper_functions
    9.                   implicit none
   10.                   character(len=32) :: arg
   11.                   integer :: i, n
   12.                   real(8) :: alpha, frac, t0, t1
   13.                   real(8), allocatable :: x(:), y(:)
   14.                 
   15.                   ! Array size
   16.                   n = 102400
   17.  +                call get_command_argument(1, arg)
   18.                   if (len_trim(arg) > 0) then
   19.                     read(arg, *) n
   20.                   end if
   21.                   print '(A, I0)', "Array size n = ", n
   22.                 
   23.                   allocate(x(n), y(n))
   24.                 
   25.                   ! Initialization
   26.                   alpha = 3.0d0
   27.    Vr2--------<   do i = 1, n
   28.    Vr2              frac = 1.0d0 / real(n - 1, kind=8)
   29.    Vr2              x(i) = real(i - 1, kind=8) * frac
   30.    Vr2              y(i) = real(i - 1, kind=8) * frac * 100.0d0
   31.    Vr2-------->   end do
   32.                 
   33.                   ! Print input values
   34.                   print '(A)', "Input:"
   35.                   print '(A, F8.4)', "a = ", alpha
   36.  + I              call print_array("x", x)
   37.  + I              call print_array("y", y)
   38.                 
   39.                   ! Calculate axpy
   40.  + MG---------<   !$omp target teams distribute parallel do
   41.    MG gr2-----<   do i = 1, n
   42.    MG gr2           y(i) = y(i) + alpha * x(i)
   43.    MG gr2----->   end do
   44.    MG--------->   !$omp end target teams distribute parallel do
   45.                 
   46.                   ! Print output values
   47.                   print '(A)', "Output:"
   48.  + I              call print_array("y", y)
   49.                 
   50.                   deallocate(x, y)
   51.                 
   52.                 end program axpy

