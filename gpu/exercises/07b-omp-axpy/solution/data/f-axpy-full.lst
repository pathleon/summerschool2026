    6.                 
    7.                 program axpy
    8.                   use helper_functions
    9.                   implicit none
   10.                   character(len=32) :: arg
   11.                   integer :: i, n
   12.                   real(8) :: alpha, frac, t0, t1
   13.                   real(8), allocatable :: x(:), y(:)
   14.                 
   15.                   ! Array size
   16.                   n = 102400
   17.  +                call get_command_argument(1, arg)
   18.                   if (len_trim(arg) > 0) then
   19.                     read(arg, *) n
   20.                   end if
   21.                   print '(A, I0)', "Array size n = ", n
   22.                 
   23.                   allocate(x(n), y(n))
   24.                 
   25.  +                !$omp target data map(alloc: x(1:n)) map(from: y(1:n))
   26.                     ! Initialization
   27.                     alpha = 3.0d0
   28.  + MG---------<     !$omp target teams distribute parallel do
   29.    MG gr2-----<     do i = 1, n
   30.    MG gr2             frac = 1.0d0 / real(n - 1, kind=8)
   31.  + MG gr2             x(i) = real(i - 1, kind=8) * frac
   32.  + MG gr2             y(i) = real(i - 1, kind=8) * frac * 100.0d0
   33.    MG gr2----->     end do
   34.    MG--------->     !$omp end target teams distribute parallel do
   35.                 
   36.                     ! Print input values
   37.                     print '(A)', "Input:"
   38.                     print '(A, F8.4)', "a = ", alpha
   39.                     !$omp target update from(x(1:n)) from(y(1:n))
   40.  + I                call print_array("x", x)
   41.  + I                call print_array("y", y)
   42.                 
   43.                     ! Calculate axpy
   44.  + MG---------<     !$omp target teams distribute parallel do
   45.    MG gr2-----<     do i = 1, n
   46.    MG gr2             y(i) = y(i) + alpha * x(i)
   47.    MG gr2----->     end do
   48.    MG--------->     !$omp end target teams distribute parallel do
   49.                   !$omp end target data
   50.                 
   51.                   ! Print output values
   52.                   print '(A)', "Output:"
   53.  + I              call print_array("y", y)
   54.                 
   55.                   deallocate(x, y)
   56.                 
   57.                 end program axpy

